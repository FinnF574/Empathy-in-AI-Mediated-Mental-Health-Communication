  },
  {
   "cell_type": "markdown",
   "id": "e52798f4-b0e1-49b6-924c-23f9e826deaa",
   "metadata": {},
   "source": [
    "BERTScore is used to measure the semantic alignment between the human therapists' responses and the LLM responses"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 62,
   "id": "e2ed57e7-992e-4f7e-a0a9-4516b4a8afee",
   "metadata": {
    "collapsed": true,
    "jupyter": {
     "outputs_hidden": true
    }
   },
