    "# Merging Title and Text"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2a7faa7c-7cad-47cf-87ed-a1e46addc176",
   "metadata": {},
   "source": [
    "In the dataset, it is a common occurrence that the question is in the title of the post, and the post itself only provides further explanation regarding the question. Therefore, the title is appended to the front of the post to ensure the LLM and the licensed therapist receive identical information."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "01655223-8e25-4320-8722-25408595ab1f",
   "metadata": {},
   "outputs": [],
   "source": [
    "def merge_title_text(title, text):\n",
    "    title = title.strip()\n",
    "    if re.search(r'[.!?]$', title):\n",
    "        return f\"{title} {text}\"\n",
    "    else:\n",
    "        return f\"{title}. {text}\"\n",
    "\n",
    "df[\"questionText\"] = df.apply(\n",
    "    lambda row: merge_title_text(row[\"questionTitle\"], row[\"questionText\"]),\n",
    "    axis=1\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "6d2082fa-aab8-4944-abdd-49a7140c8148",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = df[['questionText','answerText']]"
   ]
