  {
   "cell_type": "markdown",
   "id": "9eb2cd76-1676-4e5b-8691-7f69cc7e0259",
   "metadata": {},
   "source": [
    "The average wordcount of therapist responses is calculated (in a way that does not crash the kernel) so this data can be used for the LLM responses."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 74,
   "id": "33a73614-56b0-4299-b761-58567225da69",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Average response length (words): 169.3\n"
     ]
    }
   ],
   "source": [
    "total_words = 0\n",
    "num_answers = 0\n",
    "\n",
    "# Read CSV in chunks (safe for huge files)\n",
    "chunk_size = 10000 \n",
    "for chunk in pd.read_csv(\"Cleaned_data.csv\", chunksize=chunk_size):\n",
    "    for row in chunk.itertuples(index=False):\n",
    "        text = row.answerText\n",
    "        if pd.isna(text) or text.strip() == \"\":\n",
    "            continue\n",
    "        # Count words safely\n",
    "        total_words += len(text.split())\n",
    "        num_answers += 1\n",
    "\n",
    "# Compute average\n",
    "average_length = total_words / num_answers\n",
    "print(f\"Average response length (words): {average_length:.1f}\")"
   ]
  },
