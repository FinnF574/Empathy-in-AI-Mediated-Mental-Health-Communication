     "text": [
      "Calculating Consensus BERTScore for 862 unique scenarios...\n",
      "\n",
      "Final Consensus Scores:\n",
      "Unprompted: 0.8214\n",
      "Prompted:   0.8246\n"
     ]
    },
    {
     "data": {
