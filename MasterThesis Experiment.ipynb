    "un_ratios = test_llm['intent_un'].value_counts(normalize=True)\n",
    "pr_ratios = test_llm['intent_pr'].value_counts(normalize=True)\n",
    "\n",
    "#Structure the data for plotting\n",
    "labels = [\"Process-Oriented (Reflecting, Listening, Questioning)\", \n",
