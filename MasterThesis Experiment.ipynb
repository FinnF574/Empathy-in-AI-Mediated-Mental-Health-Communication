   "source": [
    "# Intent Classification"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5baedf16-3c21-40f1-9fc5-0b1af21029a3",
   "metadata": {},
   "source": [
    "Following the framework of Hill (2009), two different granularities of intent classification are used to determine the ratio of listening vs. helping behaviors and measure whether the LLM moves beyond understanding to provide action-oriented support in a way that aligns with expert clinical practice."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 118,
   "id": "ac290b2c-978d-4ce4-994b-8cd90a8554cb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Analyzing Compassionate Empathy Intents (Hill Framework)...\n"
     ]
    }
   ],
   "source": [
    "#Initialize Classifier\n",
    "classifier = pipeline(\"zero-shot-classification\", model=\"facebook/bart-large-mnli\", device=-1)\n",
    "\n",
    "#Define Hill-inspired Intent Labels\n",
    "candidate_labels = [\"Process-Oriented (Reflecting, Listening, Questioning)\", \n",
    "                    \"Action-Oriented (Guidance, Education, Advice)\"]\n",
    "\n",
    "def detect_helping_skill(text):\n",
    "    if pd.isna(text) or str(text).strip() == \"\":\n",
    "        return None\n",
    "    \n",
    "    result = classifier(text, candidate_labels, multi_label=False)\n",
    "    #Return the top label\n",
    "    return result['labels'][0]\n",
    "\n",
    "#Apply to subsets\n",
    "print(\"Analyzing Compassionate Empathy Intents (Hill Framework)...\")\n",
    "\n",
    "#AI Sample\n",
    "test_llm = llm_subset_unique.copy()\n",
    "test_llm['intent_un'] = test_llm['LLM_unprompted'].apply(detect_helping_skill)\n",
    "test_llm['intent_pr'] = test_llm['LLM_prompted'].apply(detect_helping_skill)\n",
    "\n",
    "#Human Sample\n",
    "test_human = human_subset.copy()\n",
    "test_human['intent'] = test_human['answerText'].apply(detect_helping_skill)"
   ]
  },
